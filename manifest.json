{
  "manifest_version": 3,
  "name": "AI Prompt 管家",
  "version": "1.0.0",
  "description": "管理你的 AI Prompt 库，一键插入 ChatGPT / Claude / DeepSeek / Kimi 等 AI 聊天工具",
  "author": "Prompt Manager",
  "homepage_url": "https://github.com/xiequanquan/ai-prompt-manager",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://kimi.moonshot.cn/*",
    "https://yuanbao.tencent.com/*",
    "https://tongyi.aliyun.com/*",
    "https://chatglm.cn/*",
    "https://www.doubao.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Prompt 管家",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://yuanbao.tencent.com/*",
        "https://tongyi.aliyun.com/*",
        "https://chatglm.cn/*",
        "https://www.doubao.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "description": "打开 Prompt 管家管理界面"
    },
    "toggle-prompt-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "在 AI 聊天页面打开 Prompt 选择器"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
